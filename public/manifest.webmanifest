{
  "name": "Planimetra",
  "short_name": "Planimetra",
  "description": "Measure. Sketch. Export. - 2D floor plans with wall, door, window, and column placement",
  "id": "https://planimetra.com/",
  "start_url": "https://planimetra.com/",
  "scope": "/",
  "display": "standalone",
  "lang": "en",
  "dir": "ltr",
  "orientation": "portrait",
  "background_color": "#111827",
  "theme_color": "#111827",
  "categories": ["productivity", "utilities", "design"],
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/mockup_banner.jpg",
      "sizes": "1360x768",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Planimetra floor plan editor"
    }
  ],
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "shortcuts": [
    {
      "name": "New Project",
      "short_name": "New",
      "description": "Start a new floor plan",
      "url": "/?new=1",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    }
  ]
}
